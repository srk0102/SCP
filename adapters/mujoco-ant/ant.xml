<mujoco model="scp-ant">
  <option timestep="0.02" integrator="RK4"/>

  <default>
    <joint armature="1" damping="1" limited="true"/>
    <geom contype="1" conaffinity="1" condim="3" density="5" friction="1 0.5 0.5" margin="0.01" rgba="0.8 0.6 0.4 1"/>
  </default>

  <worldbody>
    <light cutoff="100" diffuse="1 1 1" dir="-0 0 -1.3" directional="true" exponent="1" pos="0 0 1.3" specular=".1 .1 .1"/>
    <geom name="floor" conaffinity="1" condim="3" pos="0 0 0" rgba="0.8 0.9 0.8 1" size="40 40 40" type="plane"/>

    <body name="torso" pos="0 0 0.75">
      <freejoint name="root"/>
      <geom name="torso_geom" pos="0 0 0" size="0.25" type="sphere"/>

      <!-- Front right leg -->
      <body name="fr_leg" pos="0.2 0.2 0">
        <joint axis="0 0 1" name="fr_hip" pos="0 0 0" range="-30 30" type="hinge"/>
        <geom fromto="0 0 0 0.2 0.2 0" name="fr_upper" size="0.08" type="capsule"/>
        <body name="fr_ankle" pos="0.2 0.2 0">
          <joint axis="-1 1 0" name="fr_ankle" pos="0 0 0" range="30 70" type="hinge"/>
          <geom fromto="0 0 0 0.2 0.2 -0.5" name="fr_lower" size="0.08" type="capsule" rgba="0.7 0.4 0.2 1"/>
        </body>
      </body>

      <!-- Front left leg -->
      <body name="fl_leg" pos="-0.2 0.2 0">
        <joint axis="0 0 1" name="fl_hip" pos="0 0 0" range="-30 30" type="hinge"/>
        <geom fromto="0 0 0 -0.2 0.2 0" name="fl_upper" size="0.08" type="capsule"/>
        <body name="fl_ankle" pos="-0.2 0.2 0">
          <joint axis="1 1 0" name="fl_ankle" pos="0 0 0" range="-70 -30" type="hinge"/>
          <geom fromto="0 0 0 -0.2 0.2 -0.5" name="fl_lower" size="0.08" type="capsule" rgba="0.7 0.4 0.2 1"/>
        </body>
      </body>

      <!-- Back right leg -->
      <body name="br_leg" pos="0.2 -0.2 0">
        <joint axis="0 0 1" name="br_hip" pos="0 0 0" range="-30 30" type="hinge"/>
        <geom fromto="0 0 0 0.2 -0.2 0" name="br_upper" size="0.08" type="capsule"/>
        <body name="br_ankle" pos="0.2 -0.2 0">
          <joint axis="-1 -1 0" name="br_ankle" pos="0 0 0" range="-70 -30" type="hinge"/>
          <geom fromto="0 0 0 0.2 -0.2 -0.5" name="br_lower" size="0.08" type="capsule" rgba="0.7 0.4 0.2 1"/>
        </body>
      </body>

      <!-- Back left leg -->
      <body name="bl_leg" pos="-0.2 -0.2 0">
        <joint axis="0 0 1" name="bl_hip" pos="0 0 0" range="-30 30" type="hinge"/>
        <geom fromto="0 0 0 -0.2 -0.2 0" name="bl_upper" size="0.08" type="capsule"/>
        <body name="bl_ankle" pos="-0.2 -0.2 0">
          <joint axis="1 -1 0" name="bl_ankle" pos="0 0 0" range="30 70" type="hinge"/>
          <geom fromto="0 0 0 -0.2 -0.2 -0.5" name="bl_lower" size="0.08" type="capsule" rgba="0.7 0.4 0.2 1"/>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor joint="fr_hip" ctrlrange="-1 1" ctrllimited="true" gear="150"/>
    <motor joint="fr_ankle" ctrlrange="-1 1" ctrllimited="true" gear="150"/>
    <motor joint="fl_hip" ctrlrange="-1 1" ctrllimited="true" gear="150"/>
    <motor joint="fl_ankle" ctrlrange="-1 1" ctrllimited="true" gear="150"/>
    <motor joint="br_hip" ctrlrange="-1 1" ctrllimited="true" gear="150"/>
    <motor joint="br_ankle" ctrlrange="-1 1" ctrllimited="true" gear="150"/>
    <motor joint="bl_hip" ctrlrange="-1 1" ctrllimited="true" gear="150"/>
    <motor joint="bl_ankle" ctrlrange="-1 1" ctrllimited="true" gear="150"/>
  </actuator>
</mujoco>
