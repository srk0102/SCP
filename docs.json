  "description": "Spatial Context Protocol -- real-time AI execution runtime for embodied systems",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#4F46E5",
    "light": "#818CF8",
    "dark": "#4F46E5"
